// Prisma schema — MVP.
// SQLite برای اجرای محلی/عملیاتی (بدون نیاز به سرور). برای پروداکشن مقیاس‌پذیر،
// provider را به "postgresql" و DATABASE_URL را به رشته‌ی اتصال Postgres تغییر دهید.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  displayName   String
  // USER | GAME_ADMIN | REFEREE | SUPPORT | MAIN_ADMIN (اعتبارسنجی در لایه‌ی دامنه)
  role          String   @default("USER")
  // ACTIVE | SUSPENDED | BANNED
  accountStatus String   @default("ACTIVE")
  wallet        Wallet?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Decimal  @default(0)
  escrowBalance Decimal  @default(0)
  currency      String   @default("IRR")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// تورنومنت با مدل replay: participants و events به‌صورت JSON.
model Tournament {
  id           String   @id @default(uuid())
  title        String
  game         String?
  format       String
  genre        String
  status       String   @default("DRAFT")
  ffaRounds    Int?
  swissRounds  Int?
  participants Json
  events       Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
