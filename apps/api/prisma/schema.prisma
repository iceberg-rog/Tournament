// Prisma schema — MVP.
// SQLite برای اجرای محلی/عملیاتی (بدون نیاز به سرور). برای پروداکشن مقیاس‌پذیر،
// provider را به "postgresql" و DATABASE_URL را به رشته‌ی اتصال Postgres تغییر دهید.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  displayName   String
  // USER | GAME_ADMIN | REFEREE | SUPPORT | MAIN_ADMIN (اعتبارسنجی در لایه‌ی دامنه)
  role          String   @default("USER")
  // ACTIVE | SUSPENDED | BANNED
  accountStatus String   @default("ACTIVE")
  wallet        Wallet?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Decimal  @default(0)
  escrowBalance Decimal  @default(0)
  currency      String   @default("IRR")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// تورنومنت با مدل replay: participants و events به‌صورت JSON.
model Tournament {
  id           String   @id @default(uuid())
  title        String
  game         String?
  format       String
  genre        String
  status       String   @default("DRAFT")
  ffaRounds    Int?
  swissRounds  Int?
  participants Json
  events       Json
  // سایر فیلدهای رکورد (ظرفیت، waitlist، check-in، جوایز، هزینه‌ی ورودی، escrow، paidOut)
  meta         Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// تنظیمات پلتفرم (درگاه پرداخت، کلیدهای API، …) — یک رکورد با key="platform".
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Payment {
  id          String   @id @default(uuid())
  amount      Decimal
  description String
  status      String   @default("PENDING")
  authority   String
  ref         String?
  createdAt   DateTime @default(now())
}

// دفترِ کیف پول (مدلِ دلتا: available + escrow) برای ممیزی و بازسازی موجودی.
model Ledger {
  id             String   @id @default(uuid())
  userId         String
  type           String
  availableDelta Decimal
  escrowDelta    Decimal
  ref            String
  createdAt      DateTime @default(now())

  @@index([userId])
}

// احراز هویت (KYC) — یک پرونده per کاربر؛ پیش‌نیاز برداشت جایزه.
model KycCase {
  userId     String    @id
  status     String    @default("PENDING")
  fullName   String
  nationalId String
  reason     String?
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
}

// درخواست برداشت جایزه به حساب بانکی.
model Withdrawal {
  id         String    @id @default(uuid())
  userId     String
  amount     Decimal
  iban       String
  status     String    @default("PENDING")
  reason     String?
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@index([userId])
}

model Season {
  id            String   @id @default(uuid())
  title         String
  tournamentIds Json
  createdAt     DateTime @default(now())
}

model Space {
  id            String   @id @default(uuid())
  title         String
  tournamentId  String?
  memberIds     Json
  posts         Json
  createdAt     DateTime @default(now())
}

model Ladder {
  id        String   @id @default(uuid())
  title     String
  queue     Json
  ratings   Json
  createdAt DateTime @default(now())
}
