{
  "name": "tournament",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w @tournament/api",
    "dev:web": "npm run dev -w @tournament/web",
    "build": "npm run build -w @tournament/api && npm run build -w @tournament/web",
    "prisma:generate": "npm run prisma:generate -w @tournament/api",
    "prisma:migrate": "npm run prisma:migrate -w @tournament/api"
  },
  "engines": {
    "node": ">=20"
  }
}
